# Copy this file to .env.local / .env.staging / .env.prod and fill values.
# Commands:
# Local infra:   docker compose --env-file .env.local -f docker-compose.yml -f docker-compose.dev.yml up -d
# Staging:       docker compose --env-file .env.staging -f docker-compose.yml -f docker-compose.staging.yml up -d --build
# Production:    docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d --build

# Infrastructure
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=geolink
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@geolink.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# API container
API_HTTP_PORT=5000
JWT__KEY=CHANGE_ME_MIN_32_CHARS
JWT__ISSUER=geolink-api
JWT__AUDIENCE=geolink-app
JWT__ACCESSTOKENEXPIRATIONMINUTES=60
JWT__REFRESHTOKENEXPIRATIONDAYS=7

# Mail provider
YANDEXCLOUDPOSTBOX__ENABLED=false
YANDEXCLOUDPOSTBOX__ENDPOINT=https://postbox.cloud.yandex.net
YANDEXCLOUDPOSTBOX__FROMEMAIL=no-reply@your-domain.example
YANDEXCLOUDPOSTBOX__IAMTOKEN=
YANDEXCLOUDPOSTBOX__ACCESSKEYID=
YANDEXCLOUDPOSTBOX__SECRETACCESSKEY=
YANDEXCLOUDPOSTBOX__REGION=ru-central1
